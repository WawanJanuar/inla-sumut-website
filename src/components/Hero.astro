---
import heroImg from '../assets/images/hero-mountain.jpg';
import { Image } from 'astro:assets';
---

<section class="relative flex min-h-screen items-center overflow-hidden pt-28">
  <Image
    src={heroImg}
    alt="Pegunungan hijau — alam yang dijaga INLA SUMUT"
    class="absolute inset-0 -z-10 h-full w-full object-cover"
    widths={[640, 1080, 1600, 2000]}
    sizes="100vw"
    quality={80}
    priority
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-white/30 via-white/10 to-cream"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-white/40 via-transparent to-transparent"></div>

  <!-- Floating organic shapes -->
  <div
    class="animate-float-slow absolute -top-10 right-[8%] -z-10 h-40 w-40 rounded-full bg-leaf/25 blur-2xl sm:h-56 sm:w-56"
    aria-hidden="true"
  >
  </div>
  <div
    class="animate-float-slower absolute bottom-24 left-[4%] -z-10 h-28 w-28 rounded-full bg-forest/20 blur-2xl sm:h-44 sm:w-44"
    aria-hidden="true"
  >
  </div>
  <div
    class="animate-float-slow absolute top-1/3 left-[18%] -z-10 h-20 w-20 rounded-full bg-sky/30 blur-2xl sm:h-28 sm:w-28"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto w-full max-w-6xl px-5">
    <div class="max-w-xl rounded-[28px] bg-white/55 p-7 shadow-soft ring-1 ring-white/60 backdrop-blur-md sm:p-10" data-reveal>
      <span class="inline-flex items-center gap-2 rounded-full bg-forest/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-forest">
        <span class="h-1.5 w-1.5 rounded-full bg-leaf"></span>
        Organisasi Nirlaba
      </span>

      <h1 class="mt-5 font-display text-5xl font-extrabold leading-[1.05] text-ink sm:text-6xl">
        INLA <span class="bg-gradient-to-r from-forest to-sky bg-clip-text text-transparent">SUMUT</span>
      </h1>

      <p class="mt-3 min-h-[1.6em] text-lg font-medium text-ink-soft">
        <span id="typed-text"></span><span class="text-leaf">|</span>
      </p>

      <p class="mt-4 max-w-md text-[15px] leading-relaxed text-ink-soft">
        Sejak 2006, kami merajut cinta pada alam dan sesama melalui tarian, musik,
        dan aksi nyata di lebih dari 10 negara.
      </p>

      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href="#aktivitas"
          data-magnetic
          class="inline-flex items-center gap-2 rounded-full bg-forest px-6 py-3.5 text-sm font-semibold text-white shadow-lift transition-colors hover:bg-forest-dark"
        >
          Lihat Aktivitas Kami
          <span aria-hidden="true">↓</span>
        </a>
        <a
          href="#sekilas"
          data-magnetic
          class="inline-flex items-center gap-2 rounded-full bg-white/80 px-6 py-3.5 text-sm font-semibold text-ink ring-1 ring-ink/10 transition-colors hover:bg-white"
        >
          Sekilas Tentang Kami
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-7 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 text-xs font-semibold uppercase tracking-widest text-ink-soft">
    <span class="flex h-9 w-6 items-start justify-center rounded-full border-2 border-ink-soft/40 pt-1.5">
      <span class="h-1.5 w-1 animate-bounce rounded-full bg-forest"></span>
    </span>
    Scroll
  </div>
</section>
