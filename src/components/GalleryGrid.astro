---
interface Props {
  images?: string[];
  gallery?: string;
  colors?: string[];
  emojis?: string[];
}
const {
  images,
  gallery,
  colors = ['g1','g2','g3','g4','g5'],
  emojis = ['🌿','🌱','🍃','🌲','🌾'],
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const lb = images && gallery ? gallery : undefined;
const prefixed = images ? images.map(img => BASE + img) : undefined;
---
<div class="gallery-wrap">
  <p class="gallery-eyebrow">Galeri Foto</p>
  <div class="gallery-grid">
    <div
      class:list={['g-main g-thumb', prefixed ? '' : colors[0]]}
      {...(lb ? { 'data-gallery': lb, 'data-src': prefixed![0] } : {})}
    >
      {prefixed
        ? <img src={prefixed[0]} alt="Galeri 1" />
        : <span class="g-placeholder">{emojis[0]}</span>
      }
    </div>
    <div
      class:list={['g-thumb', prefixed ? '' : colors[1]]}
      {...(lb ? { 'data-gallery': lb, 'data-src': prefixed![1] } : {})}
    >
      {prefixed
        ? <img src={prefixed[1]} alt="Galeri 2" />
        : <span class="g-placeholder" style="font-size:28px;">{emojis[1]}</span>
      }
    </div>
    <div
      class:list={['g-thumb', prefixed ? '' : colors[2]]}
      {...(lb ? { 'data-gallery': lb, 'data-src': prefixed![2] } : {})}
    >
      {prefixed
        ? <img src={prefixed[2]} alt="Galeri 3" />
        : <span class="g-placeholder" style="font-size:28px;">{emojis[2]}</span>
      }
    </div>
    <div
      class:list={['g-thumb', prefixed ? '' : colors[3]]}
      {...(lb ? { 'data-gallery': lb, 'data-src': prefixed![3] } : {})}
    >
      {prefixed
        ? <img src={prefixed[3]} alt="Galeri 4" />
        : <span class="g-placeholder" style="font-size:28px;">{emojis[3]}</span>
      }
    </div>
    <div
      class:list={['g-thumb', prefixed ? '' : (colors[4] ?? colors[3])]}
      style="position:relative;"
      {...(lb ? { 'data-gallery': lb, 'data-src': prefixed![4] ?? prefixed![3] } : {})}
    >
      {prefixed
        ? <img src={prefixed[4] ?? prefixed[3]} alt="Galeri 5" />
        : <span class="g-placeholder" style="font-size:28px;">{emojis[4] ?? emojis[3]}</span>
      }
      <div class="g-more-overlay">
        <span class="g-more-text">+8 foto</span>
      </div>
    </div>
  </div>
</div>
