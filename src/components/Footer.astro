---
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="footer">
  <div class="footer-grid">
    <div>
      <div class="footer-brand">
        <img src={BASE + '/SRC/logo inla sumut.png'} alt="INLA" width="30" height="30" style="object-fit:contain;" />
        <span class="footer-brand-name">INLA SUMUT</span>
      </div>
      <p class="footer-tagline">International Nature Loving Association Sumatera Utara — membangun harmoni manusia, alam & semesta.</p>
    </div>
    <div>
      <p class="footer-col-title">Navigasi</p>
      <a href={BASE + '/'}           class="footer-link">Home</a>
      <a href={BASE + '/about'}      class="footer-link">About Us</a>
      <a href={BASE + '/activities'} class="footer-link">Kegiatan</a>
      <a href={BASE + '/karir'}      class="footer-link">Bergabung</a>
    </div>
    <div>
      <p class="footer-col-title">Program</p>
      <a href={BASE + '/activities/igts'}      class="footer-link">IGTS</a>
      <a href={BASE + '/activities/igt'}       class="footer-link">IGT</a>
      <a href={BASE + '/activities/mvoh'}      class="footer-link">MVOH</a>
      <a href={BASE + '/activities/pagelaran'} class="footer-link">Pagelaran SKS</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p class="footer-copy">© INLA SUMUT 2026. Dengan cinta untuk dunia.</p>
    <div class="socials">
      <a href="https://instagram.com/inlasumut" class="social-btn" target="_blank" rel="noopener">IG</a>
      <a href="https://facebook.com/inlasumut"  class="social-btn" target="_blank" rel="noopener">FB</a>
      <a href="https://youtube.com/@inlasumut"  class="social-btn" target="_blank" rel="noopener">YT</a>
    </div>
  </div>
</footer>
