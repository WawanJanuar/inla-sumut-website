---
interface RelatedItem {
  href: string;
  tag: string;
  title: string;
  description: string;
  emoji: string;
  bgClass: string;
  image?: string;
}
interface Props { items: RelatedItem[]; }
const { items } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="related-section">
  <h2 class="related-h2">Program Lainnya</h2>
  <div class="related-grid">
    {items.map(item => (
      <div class="related-card">
        <div
          class:list={['related-img', item.image ? '' : item.bgClass]}
          style={item.image ? `background-image:url('${BASE}${item.image}');background-size:cover;background-position:center;` : ''}
        >
          {!item.image && <span>{item.emoji}</span>}
        </div>
        <div class="related-body">
          <span class="related-tag-badge">{item.tag}</span>
          <h3 class="related-title">{item.title}</h3>
          <p class="related-desc">{item.description}</p>
          <a href={BASE + item.href} class="related-link">Lihat Selengkapnya <span class="arrow">→</span></a>
        </div>
      </div>
    ))}
  </div>
</section>
