---
import danceBali from '../assets/images/dance-bali.jpg';
import danceKimono from '../assets/images/dance-kimono.jpg';
import festivalStage from '../assets/images/festival-stage.jpg';
import childrenSunset from '../assets/images/children-sunset.jpg';
import { Image } from 'astro:assets';

const items = [
  { img: danceBali, tag: 'Seni & Budaya', title: 'Tari Tradisional', accent: 'forest' },
  { img: childrenSunset, tag: 'Komunitas', title: 'Kebersamaan', accent: 'sky' },
  { img: danceKimono, tag: 'Seni & Budaya', title: 'Festival Budaya', accent: 'forest' },
  { img: festivalStage, tag: 'Komunitas', title: 'Panggung Dunia', accent: 'sky' },
];
---

<section id="aktivitas" class="px-5 py-24 sm:py-32" aria-label="Sekilas aktivitas">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="inline-block rounded-full bg-forest/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-forest">
        Sekilas Aktivitas
      </span>
      <h2 class="mt-4 font-display text-3xl font-extrabold text-ink sm:text-4xl">
        Jejak Kebersamaan Kami
      </h2>
      <p class="mt-3 text-[15px] leading-relaxed text-ink-soft">
        Dari panggung seni hingga alam terbuka — setiap momen adalah ekspresi cinta
        kepada kehidupan.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <div
          class="group relative block aspect-[4/5] overflow-hidden rounded-[28px] shadow-soft"
          data-reveal
        >
          <Image
            src={item.img}
            alt={item.title}
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
            widths={[400, 700, 1000]}
            sizes="(min-width: 1024px) 25vw, 50vw"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/10 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-5 text-white">
            <span class={`rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wide backdrop-blur-sm ${item.accent === 'forest' ? 'bg-forest/80' : 'bg-sky/80'}`}>
              {item.tag}
            </span>
            <p class="mt-2 font-display text-lg font-bold">{item.title}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
