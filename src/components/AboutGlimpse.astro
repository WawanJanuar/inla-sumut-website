---
import wheatField from '../assets/images/wheat-field.jpg';
import { Image } from 'astro:assets';
---

<section id="sekilas" class="relative px-5 py-24 sm:py-32" aria-label="Sekilas tentang INLA">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="inline-block rounded-full bg-forest/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-forest">
        Sekilas Tentang Kami
      </span>
      <h2 class="mt-4 font-display text-3xl font-extrabold text-ink sm:text-4xl">
        INLA Dalam Sekejap
      </h2>
      <p class="mt-3 text-[15px] leading-relaxed text-ink-soft">
        Empat hal singkat yang menjelaskan siapa kami dan apa yang kami yakini.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Large mission tile -->
      <div
        class="group relative col-span-1 row-span-2 overflow-hidden rounded-[28px] sm:col-span-2 lg:col-span-2"
        data-reveal
      >
        <Image
          src={wheatField}
          alt="Anak bermain di ladang — keceriaan dan alam"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          widths={[480, 768, 1080]}
          sizes="(min-width: 1024px) 50vw, 100vw"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/20 to-transparent"></div>
        <div class="relative flex h-full min-h-[280px] flex-col justify-end p-7 text-white">
          <p class="font-display text-xl font-bold leading-snug sm:text-2xl">
            "Satu tarian, satu lagu, satu keluarga besar yang mencintai alam dan sesama."
          </p>
          <p class="mt-3 text-sm text-white/80">
            INLA menyebarkan nilai moral &amp; cinta alam melalui seni dan budaya
            lintas generasi sejak 2006.
          </p>
        </div>
      </div>

      <!-- Stat tiles -->
      <div class="rounded-[28px] bg-white p-6 shadow-soft ring-1 ring-black/5" data-reveal>
        <span class="font-display text-4xl font-extrabold text-forest" data-counter="2006">0</span>
        <p class="mt-2 text-sm font-semibold text-ink-soft">Tahun Berdiri</p>
      </div>
      <div class="rounded-[28px] bg-white p-6 shadow-soft ring-1 ring-black/5" data-reveal>
        <span class="font-display text-4xl font-extrabold text-forest" data-counter="10" data-suffix="+">0+</span>
        <p class="mt-2 text-sm font-semibold text-ink-soft">Negara Cabang</p>
      </div>
      <div class="rounded-[28px] bg-sand p-6 shadow-soft ring-1 ring-black/5 sm:col-span-2 lg:col-span-2" data-reveal>
        <div class="flex items-center gap-4">
          <span class="font-display text-4xl font-extrabold text-forest" data-counter="1000" data-suffix="+">0+</span>
          <p class="text-sm font-semibold text-ink-soft">
            Anggota tersebar di seluruh dunia, bergerak dalam satu visi: dunia yang
            harmonis sebagai satu keluarga.
          </p>
        </div>
      </div>
      <div class="rounded-[28px] bg-forest p-6 text-white shadow-soft sm:col-span-1 lg:col-span-2" data-reveal>
        <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 21c-4.5-1.5-7-5-7-9.5C5 7 7.5 4 12 3c4.5 1 7 4 7 8.5 0 4.5-2.5 8-7 9.5Z"></path>
          <path d="M12 21V9"></path>
        </svg>
        <p class="mt-2 text-sm font-semibold">Cinta alam &amp; seni budaya sebagai bahasa kami</p>
      </div>
      <div class="rounded-[28px] bg-sky/15 p-6 shadow-soft ring-1 ring-sky/20 sm:col-span-1 lg:col-span-2" data-reveal>
        <svg class="h-8 w-8 text-sky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 14a4 4 0 1 0-8 0"></path>
          <circle cx="12" cy="7" r="3.25"></circle>
          <path d="M5 20c0-3 2.5-5 4-5h6c1.5 0 4 2 4 5"></path>
        </svg>
        <p class="mt-2 text-sm font-semibold text-ink-soft">Merangkul semua kalangan tanpa batas</p>
      </div>
    </div>
  </div>
</section>
