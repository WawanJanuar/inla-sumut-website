---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getChannelVideosNotInPlaylists, getChannelAlbums } from '../utils/youtube';
import { audioAlbums, formatTotalDuration } from '../data/albums';

import imgDanceKimono from '../assets/images/dance-kimono.jpg';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

// Album video = playlist asli dari channel YouTube. Cover sementara pakai thumbnail
// playlist YouTube langsung (belum ada desain "Full Video" khusus per album di grid ini).
const albums = await getChannelAlbums('inlasumut');

// Video channel yang tidak masuk playlist manapun (album/koleksi terpisah rencananya tampil sendiri nanti)
const videos = await getChannelVideosNotInPlaylists('inlasumut');
---

<Layout
  title="MV & Music — INLA SUMUT"
  description="Koleksi musik dan video dari INLA — perjalanan harmoni manusia, alam, dan semesta dalam nada dan visual."
  ogImage={imgDanceKimono}
>
  <Navbar />

  <!-- HERO -->
  <section class="hero-mvmusic">
    <p class="hero-eyebrow">🎵 Musik & Visual</p>
    <h1 class="hero-h1">MV & <em>Music</em></h1>
    <p class="hero-p">Koleksi musik dan video dari INLA — perjalanan harmoni manusia, alam, dan semesta dalam nada dan visual.</p>
  </section>

  <!-- ALBUM GRID -->
  <section class="mvm-section">
    <div class="mvm-header">
      <p class="section-eyebrow">Diskografi</p>
      <h2 class="section-title">Koleksi <em>Album</em></h2>
    </div>

    <div class="album-grid">
      {albums.map((album) => (
        <a class="album-card" href={`${BASE}/mv-music/${album.slug}`}>
          <div class="album-cover">
            <img src={album.thumbnail} alt={album.title} class="album-img" loading="lazy" />
            <div class="album-overlay"></div>
          </div>
          <div class="album-title">{album.title}</div>
          <div class="album-subtitle">{album.videoCount} video · {album.totalDurationLabel}</div>
        </a>
      ))}
      {audioAlbums.map((album) => {
        const totalSeconds = album.tracks.reduce((sum, t) => sum + t.durationSeconds, 0);
        return (
          <a class="album-card" href={`${BASE}/mv-music/audio/${album.slug}`}>
            <div class="album-cover">
              <img src={`${BASE}${album.thumbnail}`} alt={album.title} class="album-img" loading="lazy" />
              <div class="album-overlay"></div>
            </div>
            <div class="album-title">{album.title}</div>
            <div class="album-subtitle">{album.tracks.length} lagu · {formatTotalDuration(totalSeconds)}</div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="divider-with-label">
    <hr />
    <span>Video & MV</span>
    <hr />
  </div>

  <!-- VIDEO GRID -->
  <section class="mvm-section mvm-section-video">
    <div class="video-search-wrap">
      <svg class="video-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
        <path d="M20 20L16.5 16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <input type="text" id="video-search" class="video-search-input" placeholder="Cari video..." autocomplete="off" />
    </div>

    {videos.length > 20 && (
      <p class="video-list-hint">Menampilkan 20 dari {videos.length} video terbaru — gunakan pencarian untuk lihat semua.</p>
    )}

    <div class="video-grid" id="video-grid">
      {videos.slice(0, 20).map((video) => (
        <div class="video-card" data-video-id={video.id} data-title={video.title.toLowerCase()} data-aspect={video.aspectRatio} role="button" tabindex="0">
          <div class="video-thumb-wrap">
            <img src={video.thumbnail} alt={video.title} class="video-thumb" loading="lazy" />
            <div class="video-overlay"></div>
            <div class="video-play-btn">
              <svg width="64" height="64" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path fill="#FF0000" d="M23.498 6.186a2.994 2.994 0 0 0-2.107-2.117C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.391.524A2.994 2.994 0 0 0 .502 6.186 31.16 31.16 0 0 0 0 12a31.16 31.16 0 0 0 .502 5.814 2.994 2.994 0 0 0 2.107 2.117c1.886.524 9.391.524 9.391.524s7.505 0 9.391-.524a2.994 2.994 0 0 0 2.107-2.117A31.16 31.16 0 0 0 24 12a31.16 31.16 0 0 0-.502-5.814Z" />
                <path fill="#FFF" d="M9.75 15.02V8.98L15.5 12l-5.75 3.02Z" />
              </svg>
            </div>
          </div>
          <div class="video-title">{video.title}</div>
          <div class="video-subtitle">{video.author} · YouTube</div>
        </div>
      ))}
    </div>

    <p class="video-search-empty" id="video-search-empty">Tidak ada video yang cocok dengan pencarian.</p>
  </section>

  <Footer />

  <div id="video-modal" class="modal-backdrop" aria-modal="true" role="dialog">
    <div class="modal-content">
      <div class="glow-outer"></div>
      <div class="glow-ring"></div>
      <div class="iframe-wrapper">
        <iframe
          id="video-iframe"
          src=""
          frameborder="0"
          allow="autoplay; encrypted-media"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-mvmusic {
    background: linear-gradient(160deg, #1c2e1c 0%, #2d4a2d 60%, #1c3a2a 100%);
    padding: 100px 40px 64px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero-mvmusic::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 40%, rgba(74,158,74,0.18) 0%, transparent 70%);
  }
  .hero-mvmusic .hero-eyebrow { position: relative; }
  .hero-mvmusic .hero-h1 { position: relative; }
  .hero-mvmusic .hero-p { position: relative; margin-left: auto; margin-right: auto; }

  .mvm-section {
    padding: 64px 10% 16px;
    background: #fff;
  }
  .mvm-section-video { padding-top: 16px; padding-bottom: 64px; }

  .mvm-header { text-align: center; margin-bottom: 36px; }

  .album-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
  }

  .album-card { display: block; text-decoration: none; color: inherit; cursor: pointer; }
  .album-cover {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 10px;
    background: #e8e4dc;
  }
  .album-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .album-card:hover .album-img { transform: scale(1.03); }
  .album-overlay {
    position: absolute;
    inset: 0;
    background: rgba(28,46,28,0);
    transition: background 0.3s ease;
    pointer-events: none;
  }
  .album-card:hover .album-overlay { background: rgba(28,46,28,0.18); }

  .album-title { font-size: 13px; font-weight: 500; color: #1c2e1c; line-height: 1.35; }
  .album-subtitle { font-size: 11px; color: #8a8a7a; margin-top: 2px; }

  .divider-with-label {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 2.5rem 10%;
  }
  .divider-with-label hr {
    flex: 1;
    border: none;
    border-top: 0.5px solid #d8d4ca;
  }
  .divider-with-label span {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8a8a7a;
    white-space: nowrap;
  }

  .video-search-wrap {
    position: relative;
    max-width: 360px;
    margin: 0 auto 32px;
  }
  .video-search-icon {
    position: absolute;
    top: 50%;
    left: 14px;
    transform: translateY(-50%);
    color: #8a8a7a;
    pointer-events: none;
  }
  .video-search-input {
    width: 100%;
    padding: 11px 16px 11px 40px;
    border-radius: 10px;
    border: 1px solid #d8d4ca;
    background: #f5f2ec;
    font-size: 13px;
    color: #1c2e1c;
    font-family: inherit;
    transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }
  .video-search-input::placeholder { color: #a8a498; }
  .video-search-input:focus {
    outline: none;
    border-color: rgba(74, 222, 128, 0.45);
    background: #fff;
    animation: searchGlowPulse 2.4s ease-in-out infinite;
  }
  @keyframes searchGlowPulse {
    0%, 100% {
      box-shadow:
        0 0 8px 2px rgba(0, 255, 136, 0.22),
        0 0 22px 5px rgba(74, 222, 128, 0.14);
    }
    50% {
      box-shadow:
        0 0 12px 3px rgba(74, 222, 128, 0.30),
        0 0 30px 7px rgba(0, 255, 136, 0.18);
    }
  }

  .video-search-empty {
    display: none;
    text-align: center;
    color: #8a8a7a;
    font-size: 13px;
    padding: 40px 0;
  }

  .video-list-hint {
    text-align: center;
    font-size: 12px;
    color: #a8a498;
    margin: -16px 0 28px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  /* :global() di semua rule kartu video — kartu hasil pencarian di-inject lewat
     innerHTML (JS), bukan ditulis di template ini, jadi gak pernah dapat atribut
     scope data-astro-cid-* dan versi scoped dari selector-selector ini gak akan
     pernah match. Pola yang sama kayak fix iframe di mv-music/[slug].astro. */
  :global(.video-card) { display: block; text-decoration: none; cursor: pointer; }
  :global(.video-thumb-wrap) {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 10px;
    background: #111;
  }
  :global(.video-thumb) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  :global(.video-card:hover .video-thumb) { transform: scale(1.02); }
  :global(.video-overlay) {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.15);
    transition: background 0.3s ease;
  }
  :global(.video-card:hover .video-overlay) { background: rgba(0,0,0,0.28); }
  :global(.video-play-btn) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.35));
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  :global(.video-play-btn svg) { width: 100%; height: 100%; }
  :global(.video-card:hover .video-play-btn) { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }

  :global(.video-title) { font-size: 13px; font-weight: 500; color: #1c2e1c; line-height: 1.35; }
  :global(.video-subtitle) { font-size: 11px; color: #8a8a7a; margin-top: 2px; }

  @media (max-width: 1024px) {
    .album-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .hero-mvmusic { padding: 90px 20px 48px; }
    .mvm-section { padding: 40px 20px 8px; }
    .mvm-section-video { padding-bottom: 48px; }
    .album-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .video-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .divider-with-label { margin: 2rem 20px; }
  }

  @media (max-width: 480px) {
    .video-grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     VIDEO MODAL
     ============================================================ */
  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    align-items: center;
    justify-content: center;
  }
  .modal-backdrop.active {
    display: flex;
    flex-direction: column;
    animation: backdropFadeIn 0.35s ease;
  }
  @keyframes backdropFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .modal-backdrop::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 35% at 15% 85%, rgba(0,255,136,0.03) 0%, transparent 60%),
      radial-gradient(ellipse 40% 55% at 85% 15%, rgba(74,222,128,0.03) 0%, transparent 60%);
    pointer-events: none;
    animation: ambientShift 8s ease infinite alternate;
  }
  @keyframes ambientShift {
    from { opacity: 0.6; }
    to   { opacity: 1; }
  }

  .modal-content {
    --video-ar: 16 / 9;
    position: relative;
    width: min(72%, 860px);
    animation: modalIn 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition: width 0.35s ease;
  }
  .modal-content.is-vertical {
    width: min(26%, 380px);
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.92) translateY(16px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .iframe-wrapper {
    position: relative;
    z-index: 1;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: var(--video-ar);
  }
  .iframe-wrapper iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  .glow-ring {
    position: absolute;
    inset: -2px;
    border-radius: 14px;
    background: linear-gradient(
      135deg,
      rgba(0, 255, 136, 0.55),
      rgba(74, 222, 128, 0.45),
      rgba(0, 204, 102, 0.50),
      rgba(0, 255, 136, 0.55)
    );
    background-size: 300% 300%;
    animation: ringRotate 4s ease infinite;
    z-index: 0;
    filter: blur(1px);
  }
  @keyframes ringRotate {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .glow-outer {
    position: absolute;
    inset: -12px;
    border-radius: 18px;
    z-index: 0;
    pointer-events: none;
    animation: glowPulse 4s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% {
      box-shadow:
        0 0 15px 3px rgba(0, 255, 136, 0.30),
        0 0 45px 8px rgba(74, 222, 128, 0.14),
        0 0 80px 18px rgba(0, 255, 136, 0.06);
    }
    50% {
      box-shadow:
        0 0 22px 5px rgba(74, 222, 128, 0.38),
        0 0 60px 14px rgba(0, 255, 136, 0.20),
        0 0 100px 26px rgba(74, 222, 128, 0.09);
    }
  }

  @media (max-width: 768px) {
    .modal-content { width: 92%; }
    .modal-content.is-vertical { width: 60%; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const modal        = document.getElementById('video-modal') as HTMLDivElement | null;
    const modalContent = document.querySelector<HTMLElement>('.modal-content');
    const iframe       = document.getElementById('video-iframe') as HTMLIFrameElement | null;

    if (!modal || !iframe) return;

    function openModal(videoId: string, aspectRatio: number) {
      if (!iframe) return;
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
      modal?.classList.add('active');
      document.body.style.overflow = 'hidden';

      modalContent?.classList.toggle('is-vertical', aspectRatio < 1);
      modalContent?.style.setProperty('--video-ar', String(aspectRatio));
    }

    function closeModal() {
      if (!iframe) return;
      modal?.classList.remove('active');
      iframe.src = '';
      document.body.style.overflow = '';
    }

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) closeModal();
    });

    // Delegasi klik/keydown di container (bukan per-kartu) — supaya kartu hasil
    // pencarian yang di-render belakangan (lihat di bawah) otomatis kebagian
    // handler ini juga, tanpa perlu re-attach listener tiap kali grid berubah.
    const videoGrid = document.getElementById('video-grid');

    function findCard(target: EventTarget | null): HTMLElement | null {
      return target instanceof HTMLElement ? target.closest('.video-card') : null;
    }

    videoGrid?.addEventListener('click', (e) => {
      const card = findCard(e.target);
      if (!card) return;
      const id = card.dataset.videoId;
      const aspectRatio = parseFloat(card.dataset.aspect ?? '1.7778');
      if (id) openModal(id, aspectRatio);
    });

    videoGrid?.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const card = findCard(e.target);
      if (!card) return;
      e.preventDefault();
      const id = card.dataset.videoId;
      const aspectRatio = parseFloat(card.dataset.aspect ?? '1.7778');
      if (id) openModal(id, aspectRatio);
    });

    // ── Search — 20 kartu pertama sudah ada di HTML (SSG), sisanya (321 video
    // lain) baru di-fetch dari /mv-music/videos.json begitu user mulai ketik.
    // Ini yang bikin ukuran HTML awal halaman ini jauh lebih kecil dibanding
    // nge-render 341 kartu sekaligus. ──────────────────────────────────────
    const searchInput = document.getElementById('video-search') as HTMLInputElement | null;
    const emptyMsg     = document.getElementById('video-search-empty');
    const listHint     = document.querySelector<HTMLElement>('.video-list-hint');
    const defaultGridHTML = videoGrid?.innerHTML ?? '';

    interface SearchVideo { id: string; title: string; thumbnail: string; author: string; aspectRatio: number }
    let allVideosPromise: Promise<SearchVideo[]> | null = null;

    function fetchAllVideos(): Promise<SearchVideo[]> {
      if (!allVideosPromise) {
        const base = (document.body.dataset.base ?? '/').replace(/\/$/, '');
        allVideosPromise = fetch(`${base}/mv-music/videos.json`).then((r) => r.json());
      }
      return allVideosPromise;
    }

    function escapeHtml(str: string): string {
      return str.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' } as Record<string, string>)[c]);
    }

    function videoCardHTML(video: SearchVideo): string {
      const title = escapeHtml(video.title);
      return `
        <div class="video-card" data-video-id="${video.id}" data-title="${escapeHtml(video.title.toLowerCase())}" data-aspect="${video.aspectRatio}" role="button" tabindex="0">
          <div class="video-thumb-wrap">
            <img src="${video.thumbnail}" alt="${title}" class="video-thumb" loading="lazy" />
            <div class="video-overlay"></div>
            <div class="video-play-btn">
              <svg width="64" height="64" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path fill="#FF0000" d="M23.498 6.186a2.994 2.994 0 0 0-2.107-2.117C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.391.524A2.994 2.994 0 0 0 .502 6.186 31.16 31.16 0 0 0 0 12a31.16 31.16 0 0 0 .502 5.814 2.994 2.994 0 0 0 2.107 2.117c1.886.524 9.391.524 9.391.524s7.505 0 9.391-.524a2.994 2.994 0 0 0 2.107-2.117A31.16 31.16 0 0 0 24 12a31.16 31.16 0 0 0-.502-5.814Z" />
                <path fill="#FFF" d="M9.75 15.02V8.98L15.5 12l-5.75 3.02Z" />
              </svg>
            </div>
          </div>
          <div class="video-title">${title}</div>
          <div class="video-subtitle">${escapeHtml(video.author)} · YouTube</div>
        </div>
      `;
    }

    let searchDebounce: ReturnType<typeof setTimeout> | undefined;

    searchInput?.addEventListener('input', () => {
      const query = searchInput.value.trim().toLowerCase();
      clearTimeout(searchDebounce);

      if (query === '') {
        if (videoGrid) videoGrid.innerHTML = defaultGridHTML;
        if (emptyMsg) emptyMsg.style.display = 'none';
        if (listHint) listHint.style.display = '';
        return;
      }

      if (listHint) listHint.style.display = 'none';

      searchDebounce = setTimeout(async () => {
        const all = await fetchAllVideos();
        const matches = all.filter((v) => v.title.toLowerCase().includes(query));

        if (!videoGrid) return;
        videoGrid.innerHTML = matches.map(videoCardHTML).join('');
        if (emptyMsg) emptyMsg.style.display = matches.length === 0 ? 'block' : 'none';
      }, 200);
    });
  });
</script>
