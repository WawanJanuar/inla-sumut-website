</Layout>

<script>
  // Highlight active page-nav item on scroll
  function initAbout() {
    const sections = ['sejarah','tujuan','target','makna','misi','perjalanan'];
    const navItems = document.querySelectorAll<HTMLAnchorElement>('.page-nav-item');
    if (!navItems.length) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const id = e.target.id;
          navItems.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + id));
        }
      });
    }, { rootMargin: '-60px 0px -60% 0px', threshold: 0 });

    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el) io.observe(el);
    });
  }

  initAbout();
  document.addEventListener('astro:after-swap', initAbout);
</script>
