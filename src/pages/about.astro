---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
import imgLogo        from '../assets/images/logo.png';
import imgChildren    from '../assets/images/children-sunset.jpg';
import imgDanceBali   from '../assets/images/dance-bali.jpg';
import imgDanceKimono from '../assets/images/dance-kimono.jpg';
import imgFestival    from '../assets/images/festival-stage.jpg';
import imgMountain    from '../assets/images/hero-mountain.jpg';
import imgWheat       from '../assets/images/wheat-field.jpg';
---

<Layout title="About Us — INLA SUMUT">
  <Navbar activePage="about" />

  <!-- HERO -->
  <section class="hero-about">
    <p class="hero-eyebrow">Tentang Kami</p>
    <h1 class="hero-about-h1">Mengenal <em>INLA SUMUT</em></h1>
    <p class="hero-about-p">The International Nature Loving Association — membangun harmoni antara manusia, alam, dan semesta sejak 2005.</p>
  </section>

  <!-- IN-PAGE NAV -->
  <nav class="page-nav" aria-label="Navigasi halaman">
    <a href="#perkenalan"  class="page-nav-item active">Perkenalan</a>
    <a href="#sejarah"     class="page-nav-item">Sejarah</a>
    <a href="#tujuan"      class="page-nav-item">Tujuan</a>
    <a href="#target"      class="page-nav-item">Target</a>
    <a href="#misi"        class="page-nav-item">Misi</a>
    <a href="#makna"       class="page-nav-item">Makna</a>
    <a href="#perjalanan"  class="page-nav-item">Perjalanan</a>
  </nav>

  <!-- PERKENALAN -->
  <section id="perkenalan" class="bg-cream">
    <div class="intro-wrap">
      <p class="eyebrow" style="text-align:center;">00 — Perkenalan</p>
      <h2 class="intro-main-h2">Mari Kenali <em>Kami</em></h2>
      <div class="intro-divider"></div>
      <div class="intro-sub-heading">Perkenalan</div>
      <p class="intro-tagline">Sebuah rumah yang penuh sukacita yang mempromosikan peradaban spiritual dan memupuk komunitas global; sebuah platform pendidikan yang melampaui kebangsaan, ras, budaya, dan kepercayaan.</p>
      <div class="finla-block">
        <p class="finla-name">Federasi Pencinta Alam Internasional<br />(F-INLA)</p>
        <p class="finla-desc">adalah organisasi nirlaba dan pendidikan internasional. Melalui konsep budaya mencintai alam, F-INLA menyatukan orang-orang yang memiliki pandangan serupa dari berbagai kebangsaan, ras, budaya, dan kepercayaan untuk mempromosikan pendidikan kehidupan, pendidikan literasi budaya, pendidikan literasi moral, pendidikan etika lingkungan, dan pendidikan kesehatan dari perspektif peradaban spiritual, yang pada akhirnya berkontribusi pada terwujudnya keluarga dunia yang harmonis dan bahagia.</p>
      </div>
    </div>
  </section>

  <!-- SEJARAH / ASAL MULA PENDIRIAN -->
  <section id="sejarah" class="sejarah-bg">
    <div class="sejarah-inner">
      <div>
        <p class="eyebrow-light">01 — Sejarah</p>
        <h2 class="sec-h2-light">Asal Mula <em>Pendirian</em></h2>
        <p class="sec-p-light">Asosiasi Pecinta Alam Internasional (INLA) pertama kali didirikan di Hong Kong, Tiongkok pada tahun 2006, dan sejak itu telah mendirikan cabang di Taiwan, Indonesia, Malaysia, Amerika Serikat, Kanada, Filipina, Australia, Singapura, Korea Selatan, dan Nepal. Cabang di negara-negara lain di kelima benua juga sedang dalam tahap perencanaan.</p>
        <p class="sec-p-light">Federasi Pencinta Alam Internasional (F-INLA) didirikan di Hong Kong, Tiongkok pada tahun 2015. Misinya adalah untuk bersama-sama menciptakan budaya, peradaban, moralitas, dan nilai-nilai baru bagi seluruh umat manusia, dan untuk bersama-sama mempraktikkan Sepuluh Prinsip Bersama (hidup berdampingan, kemakmuran bersama, kekayaan bersama, kebahagiaan bersama, perdamaian bersama, kesadaran bersama, keuntungan bersama, berkah bersama, kepemilikan bersama, dan pencapaian bersama), serta untuk menampilkan estetika "keindahan manusia," mencapai kelangsungan hidup manusia yang berkelanjutan dan membina komunitas global dengan visi dan filosofi bersama. Tujuannya adalah untuk membangun harmoni antara umat manusia dan alam dalam kesejahteraan fisik dan mental keluarga, masyarakat, bangsa, dan dunia.</p>
        <p class="sec-p-light">Pendiri sekaligus Presiden Wang Ciguang, dengan pengalaman bertahun-tahun di bidang pendidikan, sangat merasakan bahwa banyak orang saat ini, karena nilai-nilai yang menyimpang, tidak hanya mengabaikan "nilai kemanusiaan" mereka sendiri dan "nilai serta martabat kehidupan," tetapi juga secara sembrono menghancurkan alam untuk keuntungan pribadi. Oleh karena itu, sejak tahun 2001, beliau telah giat mempromosikan "budaya mencintai alam," menggunakan berbagai kegiatan pendidikan dan hiburan untuk membimbing kaum muda, remaja, dan anak-anak dalam membangun nilai-nilai yang benar dan mempraktikkan kehidupan yang melindungi, mencintai, dan merangkul kehidupan.</p>
        <div class="stats-row-sm" style="margin-top:20px;">
          <div class="stat-mini glass-card" style="padding:14px;">
            <div class="stat-mini-num">20+</div>
            <div class="stat-mini-label">Negara Anggota</div>
          </div>
          <div class="stat-mini glass-card" style="padding:14px;">
            <div class="stat-mini-num">2006</div>
            <div class="stat-mini-label">Tahun Berdiri</div>
          </div>
        </div>
        <div class="glass-card flags-card" style="margin-top:24px;">
          <p class="flags-title">Negara Anggota</p>
          <div class="flags-grid">
            <div class="flag-item"><span class="flag-emoji">🇭🇰</span><span class="flag-name">Hong Kong</span></div>
            <div class="flag-item"><span class="flag-emoji">🇹🇼</span><span class="flag-name">Taiwan</span></div>
            <div class="flag-item"><span class="flag-emoji">🇮🇩</span><span class="flag-name">Indonesia</span></div>
            <div class="flag-item"><span class="flag-emoji">🇲🇾</span><span class="flag-name">Malaysia</span></div>
            <div class="flag-item"><span class="flag-emoji">🇺🇸</span><span class="flag-name">USA</span></div>
            <div class="flag-item"><span class="flag-emoji">🇨🇦</span><span class="flag-name">Kanada</span></div>
            <div class="flag-item"><span class="flag-emoji">🇵🇭</span><span class="flag-name">Filipina</span></div>
            <div class="flag-item"><span class="flag-emoji">🇦🇺</span><span class="flag-name">Australia</span></div>
            <div class="flag-item"><span class="flag-emoji">🇸🇬</span><span class="flag-name">Singapura</span></div>
            <div class="flag-item"><span class="flag-emoji">🇰🇷</span><span class="flag-name">Korea Selatan</span></div>
            <div class="flag-item"><span class="flag-emoji">🇳🇵</span><span class="flag-name">Nepal</span></div>
          </div>
        </div>
      </div>
      <div class="sejarah-img-col">
        <img src={BASE + '/SRC/hongkong.jpg'} alt="Hong Kong — Kota Asal INLA" class="sejarah-photo" />
      </div>
    </div>
  </section>

  <!-- TUJUAN -->
  <section id="tujuan" class="bg-cream">
    <div>
      <p class="eyebrow">02 — Tujuan</p>
      <h2 class="sec-h2">Tujuan <em>F-INLA</em></h2>
      <div class="tujuan-block">
        <p class="sec-p">Untuk bersama-sama menciptakan budaya baru, peradaban baru, moralitas baru, dan nilai-nilai baru bagi seluruh umat manusia, dan untuk bersama-sama mempraktikkan semangat Sepuluh Prinsip Bersama (hidup berdampingan, kemakmuran bersama, kekayaan bersama, kebahagiaan bersama, ketenangan bersama, kesadaran bersama, keuntungan bersama, berkah bersama, kepemilikan bersama, dan prestasi bersama), serta untuk menampilkan estetika "keindahan manusia," untuk mencapai kelangsungan hidup umat manusia yang berkelanjutan, dan agar setiap orang memiliki visi dan konsep keluarga global.</p>
        <p class="sec-p" style="margin-top:16px;">Dengan mempromosikan budaya alam secara global, kita dapat mendorong setiap orang untuk menumbuhkan kecintaan terhadap alam dan membantu dunia menjadi satu keluarga secepat mungkin.</p>
      </div>
    </div>
  </section>

  <!-- TARGET -->
  <section id="target" class="bg-white">
    <div>
      <div class="target-grid">
        <div>
          <p class="eyebrow">03 — Target</p>
          <h2 class="sec-h2">Lima <em>Keharmonisan</em></h2>
          <p class="sec-p">Program kami diarahkan untuk membangun keharmonisan di setiap lapisan kehidupan — dari diri sendiri hingga seluruh dunia.</p>
        </div>
        <div class="target-list">
          <div class="target-item" data-reveal>
            <div class="target-num">1</div>
            <div class="target-text">Membangun keharmonisan pikiran dan tubuh antara manusia dan alam.</div>
          </div>
          <div class="target-item" data-reveal data-reveal-delay="1">
            <div class="target-num">2</div>
            <div class="target-text">Membangun keharmonisan keluarga antara manusia dan alam.</div>
          </div>
          <div class="target-item" data-reveal data-reveal-delay="2">
            <div class="target-num">3</div>
            <div class="target-text">Membangun keharmonisan masyarakat antara manusia dan alam.</div>
          </div>
          <div class="target-item" data-reveal data-reveal-delay="3">
            <div class="target-num">4</div>
            <div class="target-text">Membangun keharmonisan bangsa antara manusia dan alam.</div>
          </div>
          <div class="target-item" data-reveal data-reveal-delay="4">
            <div class="target-num">5</div>
            <div class="target-text">Membangun keharmonisan dunia antara manusia dan alam.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISI & TUGAS -->
  <section id="misi" class="bg-cream">
    <div>
      <p class="eyebrow">04 — Misi & Tugas</p>
      <h2 class="sec-h2">Misi dan <em>Tugas Kami</em></h2>
      <p class="sec-p misi-desc">Kami menganjurkan agar setiap orang menghormati martabat semua kehidupan! Kami mempromosikan pendidikan kehidupan yang menekankan "melindungi kehidupan sendiri dan melindungi kehidupan orang lain; mencintai kehidupan sendiri dan mencintai kehidupan orang lain; memuliakan kehidupan sendiri dan memuliakan kehidupan orang lain." Kami juga menganjurkan pendidikan karakter moral yang baik, pendidikan literasi budaya, pendidikan etika lingkungan, dan pendidikan kesehatan, mendorong setiap orang untuk kembali ke jati diri mereka yang sebenarnya dan terhubung dengan dunia alam. Hal ini akan memungkinkan kita, sebagai individu, keluarga, masyarakat, bangsa, dunia, dan seluruh alam untuk mencapai harmoni, perdamaian, dan kebahagiaan, yang pada akhirnya memungkinkan setiap orang untuk menyadari keindahan hakiki kemanusiaan dan menikmati kehidupan yang indah, keberadaan yang indah!</p>

      <div class="promosi-section">
        <h3 class="promosi-heading">Promosi dan Praktik</h3>
        <div class="promosi-list">
          <div class="promosi-item" data-reveal>
            <div class="promosi-num">1</div>
            <div class="promosi-text">Memimpin federasi internasional, menjunjung tinggi komitmen untuk melayani masyarakat.</div>
          </div>
          <div class="promosi-item" data-reveal data-reveal-delay="1">
            <div class="promosi-num">2</div>
            <div class="promosi-text">Melalui berbagai kegiatan budaya dan seni yang mengekspresikan kecintaan terhadap alam, seperti lagu-lagu alam, tarian alam, latihan bertema alam, musik alam, dan drama alam, serta secara aktif mempromosikan forum dan ceramah spiritual tentang budaya mencintai alam, kita dapat membantu orang memahami nilai-nilai yang benar, pandangan hidup, kelangsungan hidup, dan cara hidup.</div>
          </div>
          <div class="promosi-item" data-reveal data-reveal-delay="2">
            <div class="promosi-num">3</div>
            <div class="promosi-text">Mendorong kaum muda dan remaja untuk berpartisipasi dalam kegiatan yang diselenggarakan oleh Asosiasi Umum dan cabang-cabangnya, seperti menyanyikan lagu-lagu alam, menari tarian alam, melakukan latihan bertema alam, memainkan musik alam, dan menampilkan drama alam. Melalui paparan dan pengalaman yang berkelanjutan, mereka dapat menumbuhkan kecintaan terhadap dunia, manusia, dan segala sesuatu, serta semangat optimis, gigih, positif, dan berjiwa wirausaha.</div>
          </div>
          <div class="promosi-item" data-reveal data-reveal-delay="3">
            <div class="promosi-num">4</div>
            <div class="promosi-text">Untuk mendorong pengembangan budaya mencintai alam secara komprehensif, untuk membangun penelitian akademis, dan untuk menumbuhkan pemikiran yang benar dan karakter moral yang baik.</div>
          </div>
          <div class="promosi-item" data-reveal data-reveal-delay="4">
            <div class="promosi-num">5</div>
            <div class="promosi-text">Dengan menggabungkan berbagai bahasa dan budaya, kita dapat meningkatkan cakupan pertukaran internasional seni dan budaya yang unggul serta mempromosikan hubungan persahabatan antar negara.</div>
          </div>
          <div class="promosi-item" data-reveal data-reveal-delay="5">
            <div class="promosi-num">6</div>
            <div class="promosi-text">Untuk menciptakan kehidupan budaya yang beragam, berkualitas tinggi, dan kaya, serta menghubungkan kawasan ini dengan budaya internasional.</div>
          </div>
          <div class="promosi-item" data-reveal data-reveal-delay="6">
            <div class="promosi-num">7</div>
            <div class="promosi-text">Hancurkan hambatan antarmanusia dan raih dunia yang harmonis sebagai satu keluarga.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAKNA INLA -->
  <section id="makna" class="meanings-bg">
    <div class="meanings-inner">
      <p class="eyebrow-light">05 — Makna</p>
      <h2 class="meanings-h2">Makna di Balik <em style="color:#7dd87d;font-style:normal;">INLA</em></h2>
      <p class="meanings-p">Setiap huruf dalam INLA membawa makna yang dalam tentang misi dan nilai-nilai kami.</p>
      <div class="meanings-grid">
        <div class="meaning-card" data-reveal>
          <div class="meaning-icon">🌐</div>
          <div class="meaning-title">I — International</div>
          <div class="meaning-desc">Melampaui batas negara, menyatukan manusia dari berbagai penjuru dunia dalam satu visi.</div>
        </div>
        <div class="meaning-card" data-reveal data-reveal-delay="1">
          <div class="meaning-icon">🌿</div>
          <div class="meaning-title">N — Nature</div>
          <div class="meaning-desc">Alam adalah guru terbesar — kami belajar darinya dan berkomitmen untuk menjaganya.</div>
        </div>
        <div class="meaning-card" data-reveal data-reveal-delay="2">
          <div class="meaning-icon">❤️</div>
          <div class="meaning-title">L — Loving</div>
          <div class="meaning-desc">Cinta adalah kekuatan penggerak — cinta terhadap alam, sesama, dan kehidupan.</div>
        </div>
        <div class="meaning-card" data-reveal data-reveal-delay="3">
          <div class="meaning-icon">🤝</div>
          <div class="meaning-title">A — Association</div>
          <div class="meaning-desc">Bersama kita lebih kuat — komunitas adalah pondasi dari semua yang kami lakukan.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSING -->
  <div class="closing">
    <div class="closing-zh">世界一家</div>
    <div class="closing-id">Satu Dunia, Satu Keluarga</div>
    <p class="closing-p">Filosofi yang menjadi fondasi segala yang kami lakukan — bahwa seluruh umat manusia adalah satu keluarga besar.</p>
  </div>

  <!-- PERJALANAN / TIMELINE -->
  <section id="perjalanan" class="journey-bg">
    <div class="journey-inner">
      <p class="eyebrow">06 — Perjalanan</p>
      <h2 class="journey-h2">Dua Dekade <em>Bersama Alam</em></h2>
      <p class="journey-sub">Dari sebuah komunitas kecil di Hong Kong, INLA telah berkembang menjadi gerakan internasional. Berikut tonggak-tonggak perjalanan kami.</p>

      <div class="timeline">
        <div class="tl-item tl-left">
          <div class="tl-card">
            <div class="tl-year">2001</div>
            <div class="tl-title">Awal Mula Gerakan</div>
            <div class="tl-desc">Wang Ciguang mulai mempromosikan "budaya mencintai alam" melalui berbagai kegiatan pendidikan dan hiburan.</div>
          </div>
          <div class="tl-dot"></div>
          <div class="tl-empty"></div>
        </div>
        <div class="tl-item tl-right">
          <div class="tl-empty"></div>
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-year">2006</div>
            <div class="tl-title">Founding — Hong Kong</div>
            <div class="tl-desc">INLA resmi didirikan di Hong Kong, Tiongkok sebagai asosiasi pecinta alam internasional pertama.</div>
          </div>
        </div>
        <div class="tl-item tl-left">
          <div class="tl-card">
            <div class="tl-year">2008</div>
            <div class="tl-title">Ekspansi ke Indonesia</div>
            <div class="tl-desc">Cabang pertama di Indonesia dibuka di Sumatera Utara, menandai langkah besar INLA di Asia Tenggara.</div>
          </div>
          <div class="tl-dot"></div>
          <div class="tl-empty"></div>
        </div>
        <div class="tl-item tl-right">
          <div class="tl-empty"></div>
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-year">2010</div>
            <div class="tl-title">Program IGTS Pertama</div>
            <div class="tl-desc">Peluncuran program INLA Goes To School yang menjadi andalan pendidikan karakter berbasis alam.</div>
          </div>
        </div>
        <div class="tl-item tl-left">
          <div class="tl-card">
            <div class="tl-year">2012</div>
            <div class="tl-title">Pagelaran SKS I</div>
            <div class="tl-desc">Pagelaran Senam, Kebudayaan & Seni pertama digelar, menarik 3.000+ penonton dari seluruh Sumut.</div>
          </div>
          <div class="tl-dot"></div>
          <div class="tl-empty"></div>
        </div>
        <div class="tl-item tl-right">
          <div class="tl-empty"></div>
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-year">2015</div>
            <div class="tl-title">F-INLA Didirikan & IGT Season 1</div>
            <div class="tl-desc">Federasi Pencinta Alam Internasional (F-INLA) didirikan di Hong Kong. Kompetisi bakat INLA Got Talent diluncurkan pertama kali.</div>
          </div>
        </div>
        <div class="tl-item tl-left">
          <div class="tl-card">
            <div class="tl-year">2017</div>
            <div class="tl-title">MVOH Season 1</div>
            <div class="tl-desc">Musical Voice of Harmony lahir, menggabungkan musik dan pesan cinta alam dalam format konser.</div>
          </div>
          <div class="tl-dot"></div>
          <div class="tl-empty"></div>
        </div>
        <div class="tl-item tl-right">
          <div class="tl-empty"></div>
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-year">2019</div>
            <div class="tl-title">Anggota ke-1.000</div>
            <div class="tl-desc">INLA SUMUT merayakan pencapaian 1.000 anggota aktif — tonggak bersejarah dalam pertumbuhan komunitas.</div>
          </div>
        </div>
        <div class="tl-item tl-left">
          <div class="tl-card">
            <div class="tl-year">2021</div>
            <div class="tl-title">Go Digital</div>
            <div class="tl-desc">Pandemi mendorong inovasi — program dan konser INLA berhasil digelar secara virtual untuk pertama kali.</div>
          </div>
          <div class="tl-dot"></div>
          <div class="tl-empty"></div>
        </div>
        <div class="tl-item tl-right">
          <div class="tl-empty"></div>
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-year">2023</div>
            <div class="tl-title">20+ Negara Bergabung</div>
            <div class="tl-desc">Jaringan INLA kini mencakup lebih dari 20 negara, mewujudkan visi 世界一家 — satu dunia, satu keluarga.</div>
          </div>
        </div>
        <div class="tl-item tl-left">
          <div class="tl-card">
            <div class="tl-year">2025</div>
            <div class="tl-title">Generasi Baru INLA</div>
            <div class="tl-desc">Peluncuran platform digital baru dan program beasiswa untuk mendukung generasi pemimpin berikutnya.</div>
          </div>
          <div class="tl-dot"></div>
          <div class="tl-empty"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTEN TERBARU -->
  <section class="sosmed-section">
    <div class="sosmed-header">
      <span class="sosmed-eyebrow">Recent</span>
      <h2 class="sosmed-title">Konten Terbaru <em>INLA SUMUT</em></h2>
      <p class="sosmed-subtitle">Momen dan kegiatan terkini dari perjalanan kami bersama alam.</p>
    </div>

    <div class="sosmed-grid">
      <div class="sosmed-card">
        <div class="sosmed-img-wrap">
          <Image src={imgChildren} alt="Konten INLA" class="sosmed-img" width={400} height={160} />
          <div class="sosmed-img-overlay"><Image src={imgLogo} alt="INLA" class="sosmed-overlay-logo" width={44} height={44} /></div>
        </div>
        <div class="sosmed-body">
          <p class="sosmed-caption">Mengasihi alam adalah cara kita mengasihi sesama 🌿</p>
          <a href="https://www.instagram.com/inlasumut/" target="_blank" rel="noopener" class="sosmed-btn">Lihat di Instagram →</a>
        </div>
      </div>
      <div class="sosmed-card">
        <div class="sosmed-img-wrap">
          <Image src={imgMountain} alt="Konten INLA" class="sosmed-img" width={400} height={160} />
          <div class="sosmed-img-overlay"><Image src={imgLogo} alt="INLA" class="sosmed-overlay-logo" width={44} height={44} /></div>
        </div>
        <div class="sosmed-body">
          <p class="sosmed-caption">Bersama alam, kita temukan kedamaian sejati 🌄</p>
